# Backend URL for server-side API proxy rewrites (Next.js → NestJS)
# In Docker: http://backend:3020
# In local dev: http://localhost:3020
BACKEND_INTERNAL_URL=http://localhost:3020

# Public API base URL used by the browser (via Next.js rewrite proxy)
NEXT_PUBLIC_API_BASE=/api/v1

# Auth (OIDC)
NEXT_PUBLIC_OIDC_ISSUER=https://auth.padma.local
NEXT_PUBLIC_OIDC_CLIENT_ID=padma-frontend
